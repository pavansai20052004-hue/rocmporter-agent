# Local development: the Vite dev server proxies /api to this target.
VITE_API_BASE_URL=http://127.0.0.1:8000

# PRODUCTION (Vercel): set this in the Vercel dashboard
# (Project -> Settings -> Environment Variables) to your deployed Render
# backend URL, WITHOUT a trailing slash, e.g.:
#   VITE_API_BASE_URL=https://rocmporter-api.onrender.com
# The frontend calls `${VITE_API_BASE_URL}/api/...`, so if this is unset in
# production the app falls back to sample/demo data instead of real scans.
