# Optional local secrets for ROCmPorter Agent
GITHUB_PAT=ghp_your_token_here
# Optional if you want GitHub review posting to use a different variable name
# ROCMPORTER_GITHUB_TOKEN=ghp_your_token_here
# ===== AI patch generation =====
# Where the patch model runs:
#   ollama | openai | groq | openrouter | together | deepseek | anthropic
# Local dev defaults to ollama. Cloud deploys (Render) should use a hosted
# provider because Ollama cannot run on a serverless / small cloud host.
LLM_PROVIDER=ollama
# Required for every hosted provider (NOT for ollama). Keep secret; on Render
# set it in the dashboard, never in git.
# LLM_API_KEY=sk-your-key-here
# Optional: override the model (a sensible default is used per provider).
# LLM_MODEL=gpt-4o-mini
# Optional: override the provider base URL (self-hosted / proxy endpoints).
# LLM_BASE_URL=https://api.openai.com/v1

# Optional Ollama override (only used when LLM_PROVIDER=ollama)
# OLLAMA_HOST=http://127.0.0.1:11434
# Origins allowed to call this backend (local dev + hosted demos)
APP_CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178,https://pavansai20052004-hue.github.io,https://rocmporter-agent.vercel.app
# Optional: also allow Vercel preview deployments
# APP_CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app$
