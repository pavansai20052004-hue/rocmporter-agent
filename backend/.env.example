# Optional local secrets for ROCmPorter Agent
GITHUB_PAT=ghp_your_token_here
# Optional if you want GitHub review posting to use a different variable name
# ROCMPORTER_GITHUB_TOKEN=ghp_your_token_here
# Optional Ollama override
# OLLAMA_HOST=http://127.0.0.1:11434
# Origins allowed to call this backend (local dev + hosted demos)
APP_CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178,https://pavansai20052004-hue.github.io,https://rocmporter-agent.vercel.app
# Optional: also allow Vercel preview deployments
# APP_CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app$
